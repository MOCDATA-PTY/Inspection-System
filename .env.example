# Food Safety Agency System - Environment Variables
# Copy this file to .env and fill in your actual values

# Email Configuration (Same as E-Click project)
EMAIL_HOST_USER=FoodSafetyAgency@outlook.com
EMAIL_HOST_PASSWORD=your_outlook_password_here
DEFAULT_FROM_EMAIL=FoodSafetyAgency@outlook.com

# Django Settings
SECRET_KEY=your_secret_key_here
DEBUG=True

# Database (if using environment variables)
# DB_NAME=your_database_name
# DB_USER=your_database_user
# DB_PASSWORD=your_database_password
# DB_HOST=localhost
# DB_PORT=5432
